# Apache/Hostinger configuration for forcing HTTPS and routing React/Vite SPA
# Compliant with Hostinger Business Hosting environments (Apache/LiteSpeed)

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. Force HTTPS via 301 Permanent Redirect
  # Protect against infinite loops by checking HTTPS state and port
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{SERVER_PORT} 80
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 2. Rewrite non-existent file/directory requests to index.html for React SPA Routing
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# 3. Prevent Directory Listing for Enhanced Security
<IfModule mod_autoindex.c>
  Options -Indexes
</IfModule>

# 4. Set Secure Security Headers (transferred from hostinger.json configuration)
<IfModule mod_headers.c>
  # Strict-Transport-Security (HSTS)
  Header set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

  # Protect against MIME type sniffing
  Header set X-Content-Type-Options "nosniff"

  # Protect against Clickjacking / UI Redirection
  Header set X-Frame-Options "SAMEORIGIN"

  # Enable XSS filtering in browsers
  Header set X-XSS-Protection "1; mode=block"

  # Referrer Policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Content-Security-Policy (CSP) matching hostinger.json
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://apis.google.com https://www.gstatic.com https://*.firebaseapp.com https://identitytoolkit.googleapis.com; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://identitytoolkit.googleapis.com; img-src 'self' data: blob: https://*.googleapis.com https://images.unsplash.com https://images.pexels.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; frame-src 'self' https://*.firebaseapp.com;"

  # Permissions Policy
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
</IfModule>

# 5. Gzip Compression for Performance (highly recommended for Hostinger Business)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>
